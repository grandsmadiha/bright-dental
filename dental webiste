        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="num">15+</div>
            <div class="label">Years Experience</div>
          </div>
          <div class="hero-stat">
            <div class="num">10K+</div>
            <div class="label">Happy Patients</div>
          </div>
          <div class="hero-stat">
            <div class="num">98%</div>
            <div class="label">Success Rate</div>
          </div>
        </div>
      </div>
      <div class="hero-image fade-up">
        <img src="https://image.qwenlm.ai/public_source/48597f34-e1b6-41e6-a1a2-cc0fd3882369/1818d3839-e879-4398-b896-c62d24197d81.png" alt="Dr. Lin - Bright Smile Dental">
        <div class="hero-float top">
          <div class="icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div>
            <div class="txt">Board Certified</div>
            <div class="sub">Expert Dentists</div>
          </div>
        </div>
        <div class="hero-float bottom">
          <div class="icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <div>
            <div class="txt">4.9/5 Rating</div>
            <div class="sub">500+ Reviews</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-image fade-up">
        <img src="https://image.qwenlm.ai/public_source/48597f34-e1b6-41e6-a1a2-cc0fd3882369/1ca6c75b7-a09c-4db8-8fb1-22e6b97ceee8.png" alt="Bright Smile Clinic Interior">
        <div class="about-exp">
          <div class="big">15+</div>
          <div class="small">Years of Excellence</div>
        </div>
      </div>
      <div class="about-content fade-up">
